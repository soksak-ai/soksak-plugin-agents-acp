{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-agents-acp",
  "name": {
    "en": "ACP Core",
    "ko": "ACP Core"
  },
  "version": "0.0.1",
  "description": {
    "en": "Library plugin (no UI) for managing AI coding agents. Runs ACP agents (Claude, Codex, Gemini) as subprocesses and exposes the ACP communication engine via commands and events.",
    "ko": "AI \ucf54\ub529 \uc5d0\uc774\uc804\ud2b8\ub97c \ub2e4\ub8e8\ub294 \ub77c\uc774\ube0c\ub7ec\ub9ac \ud50c\ub7ec\uadf8\uc778(UI \uc5c6\uc74c). Claude\u00b7Codex\u00b7Gemini \uac19\uc740 ACP \uc5d0\uc774\uc804\ud2b8\ub97c \uc11c\ube0c\ud504\ub85c\uc138\uc2a4\ub85c \uc2e4\ud589\ud558\uace0, \ud45c\uc900 \ud504\ub85c\ud1a0\ucf5c(ACP)\ub85c \ud1b5\uc2e0\ud558\ub294 \uc5d4\uc9c4\uc744 \ucee4\ub9e8\ub4dc\u00b7\uc774\ubca4\ud2b8\ub85c \ub178\ucd9c\ud55c\ub2e4."
  },
  "entry": "main.js",
  "permissions": [
    "process",
    "commands",
    "fs:read",
    "fs:write"
  ],
  "libraries": [
    {
      "name": "@agentclientprotocol/claude-agent-acp",
      "bin": "claude-agent-acp",
      "label": "Claude ACP \uc5b4\ub311\ud130",
      "install": {
        "darwin": "npm i -g @agentclientprotocol/claude-agent-acp@latest",
        "linux": "npm i -g @agentclientprotocol/claude-agent-acp@latest",
        "win32": "npm i -g @agentclientprotocol/claude-agent-acp@latest"
      }
    },
    {
      "name": "@agentclientprotocol/codex-acp",
      "bin": "codex-acp",
      "label": "Codex ACP \uc5b4\ub311\ud130",
      "install": {
        "darwin": "npm i -g @agentclientprotocol/codex-acp@latest",
        "linux": "npm i -g @agentclientprotocol/codex-acp@latest",
        "win32": "npm i -g @agentclientprotocol/codex-acp@latest"
      }
    },
    {
      "name": "@google/gemini-cli",
      "bin": "gemini",
      "label": "Gemini CLI",
      "install": {
        "darwin": "npm i -g @google/gemini-cli@latest",
        "linux": "npm i -g @google/gemini-cli@latest",
        "win32": "npm i -g @google/gemini-cli@latest"
      }
    }
  ],
  "contributes": {
    "commands": [
      {
        "name": "ping",
        "title": {
          "en": "Ping (load/version check)",
          "ko": "ACP \ucf54\uc5b4 \uc801\uc7ac/\ubc84\uc804 \ud655\uc778(E2E)"
        }
      },
      {
        "name": "exec",
        "title": {
          "en": "Exec (process primitive)",
          "ko": "\uc678\ubd80 \ud504\ub85c\uadf8\ub7a8 \uc2e4\ud589(process primitive)"
        }
      },
      {
        "name": "connect",
        "title": {
          "en": "Connect Agent",
          "ko": "ACP \uc5d0\uc774\uc804\ud2b8 \uc5f0\uacb0"
        }
      },
      {
        "name": "session-new",
        "title": {
          "en": "New ACP Session",
          "ko": "\uc0c8 ACP \uc138\uc158"
        }
      },
      {
        "name": "prompt",
        "title": {
          "en": "Send Prompt",
          "ko": "\ud504\ub86c\ud504\ud2b8 \uc804\uc1a1"
        }
      },
      {
        "name": "cancel",
        "title": {
          "en": "Cancel Turn",
          "ko": "\ud134 \ucde8\uc18c"
        }
      },
      {
        "name": "disconnect",
        "title": {
          "en": "Disconnect",
          "ko": "\uc5f0\uacb0 \uc885\ub8cc"
        }
      },
      {
        "name": "connections",
        "title": {
          "en": "Active Connections",
          "ko": "\ud65c\uc131 \uc5f0\uacb0 \ubaa9\ub85d"
        }
      }
    ]
  }
}
