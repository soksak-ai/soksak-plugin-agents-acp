{
  "name": "soksak-plugin-agents-acp",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "AI 코딩 에이전트(ACP)를 다루는 soksak 라이브러리 플러그인 — 에이전트를 서브프로세스로 실행하고 표준 프로토콜로 통신하는 엔진을 커맨드·이벤트로 노출.",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "doctor": "soksak-plugin-doctor",
    "prepublishOnly": "npm run build && npm run doctor"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.26.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "esbuild": "^0.24.2",
    "typescript": "~5.9.3",
    "vitest": "^2.1.8",
    "soksak-plugin-doctor": "github:soksak-ai/soksak-plugin-doctor"
  }
}
